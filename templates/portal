{% extends 'base.html' %}{% block content %}<main class="portal"><section class="portal-head"><div><span class="badge">Portal do cliente</span><h1>Olá, {{ cliente.nome }}</h1><p>Envie seus documentos do Imposto de Renda de forma simples e segura.</p></div><div class="company">{{ cliente.empresa.nome }}</div></section><section class="docs">{% for d in cliente.documentos %}<article class="doc {{ d.status }}"><div><h3>{{ '✅' if d.status == 'enviado' else '📌' }} {{ d.nome }}</h3><p>{{ 'Recebido em ' ~ d.enviado_em.strftime('%d/%m/%Y %H:%M') if d.status == 'enviado' and d.enviado_em else 'Pendente de envio' }}</p>{% if d.nome_original %}<small>Arquivo: {{ d.nome_original }}</small>{% endif %}</div><form method="post" enctype="multipart/form-data" action="{{ url_for('upload_doc', token=cliente.token, doc_id=d.id) }}"><input type="file" name="arquivo" required><button class="btn primary">Enviar</button></form></article>{% endfor %}</section></main>{% endblock %}
